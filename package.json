    "smoke:playback": "node scripts/smoke-playback.js",
    "smoke:spotify-search": "node scripts/smoke-spotify-search-service.js",
    "smoke:invite": "node scripts/smoke-invite-links.js",
    "smoke:share": "node scripts/smoke-share-message.js",
    "smoke:supabase": "node scripts/smoke-supabase-schema.js",
    "verify": "npm run check:platform && npm run check:build && npm run check:release-docs && npm run smoke:local && npm run smoke:random && npm run smoke:playback && npm run smoke:spotify-search && npm run smoke:invite && npm run smoke:share && npm run smoke:supabase && npx tsc --noEmit && node --check backend/spotify/search-server.js"
